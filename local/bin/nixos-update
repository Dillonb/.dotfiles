#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: $0 [check|switch|boot|test|dry-activate]"
    exit 1
else
    operation="$1"
fi

hostname=$(hostname)
derivation=$(curl -fsSL "https://github.com/Dillonb/.dotfiles/releases/download/system-$hostname/store-path")

if [ -z "$derivation" ]; then
    echo "No successful system build found for $hostname" >&2
    exit 1
fi

nixos-from-derivation "$derivation" "$operation"
