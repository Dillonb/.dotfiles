#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: $0 [check|switch|boot|test|dry-activate]"
    exit 1
else
    operation="$1"
fi

derivation=$(curl -fsSL https://github.com/Dillonb/.dotfiles/releases/download/latest/systems.json | jq -r --arg h "$(hostname)" '.[$h]')

if [ -z "$derivation" ] || [ "$derivation" = "null" ]; then
    echo "No store path found for $(hostname) in the latest systems.json manifest" >&2
    exit 1
fi

nixos-from-derivation "$derivation" "$operation"
